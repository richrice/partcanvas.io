# Postgres connection. For local development run `docker compose up -d postgres`
# and keep the value below (matches the compose service credentials). When unset,
# the app boots without a database and skips migrations.
DATABASE_URL=postgres://partcanvas:partcanvas@localhost:5432/partcanvas

# Auth (Better Auth). Generate a secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# OAuth apps (callbacks: $BETTER_AUTH_URL/api/auth/callback/{github,google})
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Bare Node deployments: point this at a durable mounted filesystem path.
PARTCANVAS_DATA_DIR=.data/models

# Docker Compose host ports. The containers always listen on 3000 / 5432.
PARTCANVAS_PORT=3000
PARTCANVAS_POSTGRES_PORT=5432
